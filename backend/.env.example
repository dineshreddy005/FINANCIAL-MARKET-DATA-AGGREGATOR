DATABASE_URL=postgresql+asyncpg://fmda:fmda@postgres:5432/fmda
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-this-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=120
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# --- Caching layer (requirement 6) -----------------------------------------
CACHE_TTL_LIVE_SECONDS=5
CACHE_TTL_STATIC_SECONDS=3600

# --- AI integration (optional) ----------------------------------------------
# Leave blank to run the AI features (insights + chat) on the free,
# zero-cost statistical fallback. Set a real key to upgrade to live LLM
# narratives -- no code changes required either way.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Data Providers ---------------------------------------------------------
FINNHUB_API_KEY=
